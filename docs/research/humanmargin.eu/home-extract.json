"div\",\"cls\":\"elementor-element elementor-widget elementor-widget-heading\",\"widget\":\"heading.default\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(17, 16, 16)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"width\":\"633.625px\",\"height\":\"96px\",\"maxWidth\":\"100%\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"gap\":\"20px\",\"borderColor\":\"rgb(17, 16, 16)\",\"position\":\"relative\",\"transition\":\"background 0.3s, border 0.3s, border-radius 0.3s, box-shadow 0.3s, transform 0.4s\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,1965,634,96],\"kids\":[{\"tag\":\"h2\",\"cls\":\"elementor-heading-title elementor-size-default\",\"text\":\"Voor zij die lezen, maar niet zomaar aannemen\",\"s\":{\"fontSize\":\"40px\",\"fontWeight\":\"400\",\"fontFamily\":\"\\\"Archivo Black\\\", sans-serif\",\"lineHeight\":\"48px\",\"color\":\"rgb(255, 255, 255)\",\"textTransform\":\"uppercase\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"width\":\"633.625px\",\"height\":\"96px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,1965,634,96],\"kids\":[]}]},{\"tag\":\"div\",\"cls\":\"elementor-element elementor-widget elementor-widget-heading\",\"widget\":\"heading.default\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(17, 16, 16)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"width\":\"633.625px\",\"height\":\"93.6094px\",\"maxWidth\":\"100%\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"gap\":\"20px\",\"borderColor\":\"rgb(17, 16, 16)\",\"position\":\"relative\",\"transition\":\"background 0.3s, border 0.3s, border-radius 0.3s, box-shadow 0.3s, transform 0.4s\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2081,634,94],\"kids\":[{\"tag\":\"h3\",\"cls\":\"elementor-heading-title elementor-size-default\",\"text\":\"Voor zij die willen verstaan. Omdat ze begrijpen dat vrijheid en autonomie samengaan met begrip.\",\"s\":{\"fontSize\":\"26px\",\"fontWeight\":\"500\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"31.2px\",\"color\":\"rgb(237, 255, 0)\",\"textTransform\":\"uppercase\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"width\":\"633.625px\",\"height\":\"93.6094px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(237, 255, 0)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2081,634,94],\"kids\":[]}]},{\"tag\":\"div\",\"cls\":\"elementor-element elementor-widget elementor-widget-text-editor\",\"widget\":\"text-editor.default\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"width\":\"633.625px\",\"height\":\"714.469px\",\"maxWidth\":\"100%\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"gap\":\"20px\",\"borderColor\":\"rgb(255, 255, 255)\",\"position\":\"relative\",\"transition\":\"background 0.3s, border 0.3s, border-radius 0.3s, box-shadow 0.3s, transform 0.4s\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2195,634,714],\"kids\":[{\"tag\":\"p\",\"text\":\"Voor zij die dingen in twijfel trekken. Niet omdat het kan, maar omdat het moet.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2195,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Voor zij die doorhebben wat er op het spel staat. Die te hard gewerkt hebben aan hun vrijheid om die nu uit handen te geven.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2236,634,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Aan anderen, of aan AI.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2304,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Zij zijn wij.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2346,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Wij zijn niet tegen AI. Wij zijn anti-zombie en pro-mens. We zijn tegen zij die ons willen overtuigen dat AI een trein is die je moet halen, in plaats van een krachtig gereedschap dat je bewust moet inzetten.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"81px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2387,634,81],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Tegen gedachteloos AI-gebruik. Tegen het uitbesteden van ons denken.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2483,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Tegen het idee dat sneller altijd beter is, en productiviteit het hoogste goed is.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2524,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"De mens is geen fabriek. AI is geen religie. En autonomie is geen detail.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2565,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Wij geloven dat AI een gereedschap is. Krachtig, nuttig, soms briljant. Maar alleen als je begrijpt wat je gebruikt, waarom, en welke gevolgen dat heeft.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2607,634,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Want de grootste risico’s ontstaan niet doordat mensen AI gebruiken. Ze ontstaan doordat mensen AI gebruiken zonder te begrijpen wat ze gebruiken.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2675,634,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Begrip is autonomie. Nieuwsgierigheid is verzet.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2743,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Daarom bestaat Human Margin.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2785,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Lees het\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,2826,634,27],\"kids\":[{\"tag\":\"span\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(237, 255, 0)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"display\":\"inline\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(237, 255, 0)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[477,