"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(17, 16, 16)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"paddingBottom\":\"10px\",\"width\":\"584.016px\",\"height\":\"324.953px\",\"maxWidth\":\"100%\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"gap\":\"20px\",\"borderColor\":\"rgb(17, 16, 16)\",\"position\":\"relative\",\"transition\":\"background 0.3s, border 0.3s, border-radius 0.3s, box-shadow 0.3s, transform 0.4s\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[144,4066,584,325],\"kids\":[{\"tag\":\"p\",\"text\":\"Geen juristenkantoor of standaard AI-compliancebureau. Onleesbaarheid is een verdienmodel. Dat breken we door.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(17, 16, 16)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"584.016px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(17, 16, 16)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[144,4066,584,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Want om je autonomie te bewaren moet je eerst begrijpen.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(17, 16, 16)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"584.016px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(17, 16, 16)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[144,4135,584,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"We werken volgens de Human Margin Methode, en die vertrekt van drie simpele vragen:\",\"s\":{\"fontSize\":