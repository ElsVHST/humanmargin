"50% 50%\"},\"rect\":[403,3221,634,288],\"kids\":[{\"tag\":\"p\",\"text\":\"Dat is de definitie. Maar wat wil dat in godsnaam zeggen in de praktijk?\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"27px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,3221,634,27],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Dat iedereen die AI gebruikt voor zijn werk aan een aantal vereisten moet voldoen.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,3262,634,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Denk je nu: dit is niets voor mij want ik werk enkel met mijn lievelingsmannen Chat en Claude.\",\"s\":{\"fontSize\":\"18px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"27px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"backgroundPosition\":\"0% 0%\",\"marginBottom\":\"14.4px\",\"width\":\"633.625px\",\"height\":\"54px\",\"display\":\"block\",\"flexDirection\":\"row\",\"flexWrap\":\"nowrap\",\"borderColor\":\"rgb(255, 255, 255)\",\"transition\":\"all\",\"objectFit\":\"fill\",\"objectPosition\":\"50% 50%\"},\"rect\":[403,3330,634,54],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Dan heb je even een AI Reality Check nodig. Want helaas pindakaas geldt