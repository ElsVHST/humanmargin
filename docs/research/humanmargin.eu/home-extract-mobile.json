xt\":\"Zij zijn wij.\",\"s\":{\"fontSize\":\"17px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"25.5px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"marginBottom\":\"27.2px\",\"width\":\"331.5px\",\"display\":\"block\",\"flexDirection\":\"row\",\"objectFit\":\"fill\"},\"rect\":[29,2127,332,26],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Wij zijn niet tegen AI. Wij zijn anti-zombie en pro-mens. We zijn tegen zij die \",\"s\":{\"fontSize\":\"17px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"25.5px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"marginBottom\":\"27.2px\",\"width\":\"331.5px\",\"display\":\"block\",\"flexDirection\":\"row\",\"objectFit\":\"fill\"},\"rect\":[29,2180,332,128],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Tegen gedachteloos AI-gebruik. Tegen het uitbesteden van ons denken.\",\"s\":{\"fontSize\":\"17px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"25.5px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"marginBottom\":\"27.2px\",\"width\":\"331.5px\",\"display\":\"block\",\"flexDirection\":\"row\",\"objectFit\":\"fill\"},\"rect\":[29,2334,332,51],\"kids\":[]},{\"tag\":\"p\",\"text\":\"Tegen het idee dat sneller altijd beter is, en productiviteit het hoogste goed i\",\"s\":{\"fontSize\":\"17px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"25.5px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"marginBottom\":\"27.2px\",\"width\":\"331.5px\",\"display\":\"block\",\"flexDirection\":\"row\",\"objectFit\":\"fill\"},\"rect\":[29,2412,332,51],\"kids\":[]},{\"tag\":\"p\",\"text\":\"De mens is geen fabriek. AI is geen religie. En autonomie is geen detail.\",\"s\":{\"fontSize\":\"17px\",\"fontWeight\":\"400\",\"fontFamily\":\"Archivo, sans-serif\",\"lineHeight\":\"25.5px\",\"color\":\"rgb(255, 255, 255)\",\"textAlign\":\"start\",\"marginBottom\":\"27.2px\",\"width\":\"331.5