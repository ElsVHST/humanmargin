":"block","flexDirection":"row","flexWrap":"nowrap","borderColor":"rgb(17, 16, 16)","transition":"all","objectFit":"fill"},"rect":[144,567,584,27],"kids":[]},{"tag":"p","text":"Veel ligt voorlopig nog op mijn fysieke leestafel. Met potloodstrepen in de marge en post-its ertussen.","s":{"fontSize":"18px","fontWeight":"400","fontFamily":"Archivo, sans-serif","lineHeight":"27px","color":"rgb(17, 16, 16)","textAlign":"start","backgroundPosition":"0% 0%","marginBottom":"14.4px","width":"584.016px","height":"54px","display":"block","flexDirection":"row","flexWrap":"nowrap","borderColor":"rgb(17, 16, 16)","transition":"all","objectFit":"fill"},"rect":[144,608,584,54],"kids":[]},{"tag":"p","text":"En een hoop dingen waar ik nog iets van moet vinden.","s":{"fontSize":"18px","fontWeight":"400","fontFamily":"Archivo, sans-serif","lineHeight":"27px","color":"rgb(17, 16, 16)","textAlign":"start","backgroundPosition":"0% 0%","marginBottom":"14.4px","width":"584.016px","height":"27px","display":"block","flexDirection":"row","flexWrap":"nowrap","borderColor":"rgb(17, 16, 16)","transition":"all","objectFit":"fill"},"rect":[144,677,584,27],"kids":[]},{"tag":"p","text":"Maar kom gerust terug. Er ligt regelmatig iets nieuws.","s":{"fontSize":"18px","fontWeight":"400","fontFamily":"Archivo, sans-serif","lineHeight":"27px","color":"rgb(17, 16, 16)","textAlign":"start","backgroundPosition":"0% 0%","marginBottom":"14.4px","width":"584.016px","height":"27px","display":"block","flexDirection":"row","flexWrap":"nowrap","borderColor":"rgb(17, 16, 16)","transition":"all","objectFit":"fill"},"rect":[144,718,584,27],"kids":[]}]}]},{"tag":"div","settings":"{\"background_background\":\"classic\"}","s":{"fontSize":"18px","fontWeight":"400","fontFamily":"Archivo, sans-serif","lineHeight":"27px","color":"rgb(17, 16, 16)","textAlign":"start","backgroundImage":"url(\"https://humanmargin.eu/wp-content/uploads/2026/06/MARGESCHRIJVER-3.jpg\")","backgroundSize":"cover","backgroundPosition":"50% 50%","width"